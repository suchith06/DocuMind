# =============================================================
#  DocuMind — secret keys
# =============================================================
# 1. Copy this file and rename the copy to ".env"
# 2. Paste your real values after the "=" signs (no quotes, no spaces)
# 3. NEVER share or upload your .env file — it holds your private key
# -------------------------------------------------------------

# Your IBM Cloud API key.
# Get it from: https://cloud.ibm.com/iam/apikeys  -> "Create"
WATSONX_APIKEY=your-ibm-cloud-api-key-here

# Your watsonx.ai project ID.
# Find it in your watsonx project -> Manage -> General -> Project ID
WATSONX_PROJECT_ID=your-watsonx-project-id-here

# The watsonx.ai service URL for your region.
# Common values:
#   US Dallas      -> https://us-south.ml.cloud.ibm.com
#   EU Frankfurt   -> https://eu-de.ml.cloud.ibm.com
#   GB London      -> https://eu-gb.ml.cloud.ibm.com
#   JP Tokyo       -> https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com
